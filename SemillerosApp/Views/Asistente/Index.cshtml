@{
    var rolActual = SemillerosApp.Filters.RoleAuthorizeAttribute.GetUserRole(new System.Web.HttpContextWrapper(HttpContext.Current));
    Layout = rolActual == "Admin"
        ? "~/Views/Shared/_LayoutAdmin.cshtml"
        : "~/Views/Shared/_LayoutLider.cshtml";

    ViewBag.Title = "Asistente IA";
    ViewBag.ActiveMenu = "asistente";
    ViewBag.PageTitle = "Asistente IA";
    ViewBag.PageSubtitle = "Consulta inteligente sobre semilleros";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="section-card" style="height:calc(100vh - 180px); display:flex; flex-direction:column;">

            <!-- Header del chat -->
            <div class="section-header">
                <div style="display:flex; align-items:center; gap:12px;">
                    <div style="width:40px;height:40px;background:linear-gradient(135deg,#4285f4,#34a853);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                        <i class="fas fa-robot" style="color:#fff;font-size:1rem;"></i>
                    </div>
                    <div>
                        <h2 style="margin:0">Asistente Semilleros</h2>
                        <span style="font-size:.7rem;color:#28b463;font-weight:600;">
                            <i class="fas fa-circle" style="font-size:.5rem;margin-right:3px;"></i>Activo — LLaMA 3
                        </span>
                    </div>
                </div>
                <button onclick="limpiarChat()" style="background:none;border:1px solid #dee2e6;border-radius:8px;padding:6px 12px;font-size:.75rem;color:#777;cursor:pointer;font-family:'Poppins',sans-serif;">
                    <i class="fas fa-trash-alt me-1"></i>Limpiar
                </button>
            </div>

            <!-- Área de mensajes -->
            <div id="chatBox" style="flex:1; overflow-y:auto; padding:20px; display:flex; flex-direction:column; gap:14px;">
                <!-- Mensaje de bienvenida -->
                <div class="msg-ia">
                    <div class="msg-avatar ia"><i class="fas fa-robot"></i></div>
                    <div class="msg-bubble ia">
                        ¡Hola! Soy tu asistente de investigación. Puedo ayudarte con información sobre semilleros, proyectos, gestión de investigadores y mucho más. ¿En qué te puedo ayudar hoy?
                    </div>
                </div>
            </div>

            <!-- Input -->
            <div style="padding:16px 20px; border-top:1px solid #f0f4f8;">
                <div style="display:flex; gap:10px; align-items:flex-end;">
                    <textarea id="inputMensaje" rows="1"
                              placeholder="Escribe tu pregunta sobre semilleros de investigación..."
                              style="flex:1; resize:none; padding:11px 14px; border:2px solid #dee2e6; border-radius:12px; font-family:'Poppins',sans-serif; font-size:.85rem; transition:border-color .2s; max-height:120px; overflow-y:auto;"
                              onkeydown="handleKey(event)"
                              oninput="autoResize(this)"></textarea>
                    <button id="btnEnviar" onclick="enviarMensaje()"
                            style="width:46px;height:46px;background:linear-gradient(135deg,#1a5276,#2e86c1);border:none;border-radius:12px;color:#fff;font-size:1rem;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:opacity .2s;">
                        <i class="fas fa-paper-plane" id="iconEnviar"></i>
                    </button>
                </div>
                <div style="margin-top:8px; display:flex; gap:8px; flex-wrap:wrap;">
                    <span style="font-size:.68rem;color:#aaa;">Sugerencias:</span>
                    <button class="chip" onclick="usarChip('¿Qué es un semillero de investigación?')">¿Qué es un semillero?</button>
                    <button class="chip" onclick="usarChip('¿Cómo puedo mejorar la gestión de mi semillero?')">Mejorar gestión</button>
                    <button class="chip" onclick="usarChip('¿Cuáles son las etapas de un proyecto de investigación?')">Etapas de proyecto</button>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .msg-ia, .msg-user {
        display: flex;
        align-items: flex-start;
        gap: 10px;
    }

    .msg-user {
        flex-direction: row-reverse;
    }

    .msg-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
        color: #fff;
        flex-shrink: 0;
    }

        .msg-avatar.ia {
            background: linear-gradient(135deg,#4285f4,#34a853);
        }

        .msg-avatar.user {
            background: linear-gradient(135deg,#1a5276,#2e86c1);
        }

    .msg-bubble {
        max-width: 75%;
        padding: 12px 16px;
        border-radius: 16px;
        font-size: .84rem;
        line-height: 1.6;
        word-break: break-word;
    }

        .msg-bubble.ia {
            background: #f0f4f8;
            color: #2c3e50;
            border-radius: 4px 16px 16px 16px;
        }

        .msg-bubble.user {
            background: linear-gradient(135deg,#1a5276,#2e86c1);
            color: #fff;
            border-radius: 16px 4px 16px 16px;
        }

        .msg-bubble.typing {
            display: flex;
            gap: 5px;
            align-items: center;
            padding: 14px 18px;
        }

    .dot {
        width: 7px;
        height: 7px;
        background: #aaa;
        border-radius: 50%;
        animation: bounce .9s infinite;
    }

        .dot:nth-child(2) {
            animation-delay: .2s
        }

        .dot:nth-child(3) {
            animation-delay: .4s
        }

    @@keyframes bounce {
        0%, 60%, 100% {
            transform: translateY(0)
        }

        30% {
            transform: translateY(-8px)
        }
    }

    .chip {
        font-size: .68rem;
        padding: 3px 10px;
        background: #f0f4f8;
        border: 1px solid #dee2e6;
        border-radius: 20px;
        color: #555;
        cursor: pointer;
        font-family: 'Poppins',sans-serif;
        transition: background .2s;
    }

        .chip:hover {
            background: #e0eaf5;
            color: #1a5276;
        }

    #inputMensaje:focus {
        outline: none;
        border-color: #2e86c1;
        box-shadow: 0 0 0 3px rgba(46,134,193,.1);
    }
</style>

@section Scripts {
    <script>
    var enviando = false;

    function handleKey(e) {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); enviarMensaje(); }
    }

    function autoResize(el) {
        el.style.height = 'auto';
        el.style.height = Math.min(el.scrollHeight, 120) + 'px';
    }

    function usarChip(texto) {
        document.getElementById('inputMensaje').value = texto;
        enviarMensaje();
    }

    function limpiarChat() {
        var box = document.getElementById('chatBox');
        box.innerHTML = '';
        agregarMensaje('ia', '¡Listo! Chat limpiado. ¿En qué puedo ayudarte?');
    }

    function agregarMensaje(tipo, texto) {
        var box = document.getElementById('chatBox');
        var icon = tipo === 'ia' ? '<i class="fas fa-robot"></i>' : '<i class="fas fa-user"></i>';
        var div = document.createElement('div');
        div.className = 'msg-' + tipo;
        div.innerHTML = '<div class="msg-avatar ' + tipo + '">' + icon + '</div>' +
                        '<div class="msg-bubble ' + tipo + '">' + texto + '</div>';
        box.appendChild(div);
        box.scrollTop = box.scrollHeight;
        return div;
    }

    function mostrarTyping() {
        var box = document.getElementById('chatBox');
        var div = document.createElement('div');
        div.className = 'msg-ia'; div.id = 'typing';
        div.innerHTML = '<div class="msg-avatar ia"><i class="fas fa-robot"></i></div>' +
                        '<div class="msg-bubble typing"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>';
        box.appendChild(div);
        box.scrollTop = box.scrollHeight;
    }

    function quitarTyping() {
        var t = document.getElementById('typing');
        if (t) t.remove();
    }

    function enviarMensaje() {
        if (enviando) return;
        var input   = document.getElementById('inputMensaje');
        var mensaje = input.value.trim();
        if (!mensaje) return;

        enviando = true;
        input.value = '';
        input.style.height = 'auto';
        document.getElementById('btnEnviar').style.opacity = '.5';

        agregarMensaje('user', mensaje);
        mostrarTyping();

        $.ajax({
            url: '@Url.Action("Preguntar","Asistente")',
            method: 'POST',
            data: { mensaje: mensaje, __RequestVerificationToken: $('[name=__RequestVerificationToken]').val() },
            success: function(r) {
                quitarTyping();
                if (r.respuesta) agregarMensaje('ia', r.respuesta.replace(/\n/g, '<br>'));
                else agregarMensaje('ia', '⚠️ ' + (r.error || 'Error desconocido.'));
            },
            error: function() {
                quitarTyping();
                agregarMensaje('ia', '⚠️ No se pudo conectar con el asistente. Verifica tu conexión.');
            },
            complete: function() {
                enviando = false;
                document.getElementById('btnEnviar').style.opacity = '1';
            }
        });
    }
    </script>
    @Html.AntiForgeryToken()
}