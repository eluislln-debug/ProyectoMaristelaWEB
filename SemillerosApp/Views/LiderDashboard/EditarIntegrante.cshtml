@model SemillerosApp.Models.Investigadores
@{
    Layout = "~/Views/Shared/_LayoutLider.cshtml";
    ViewBag.Title = "Editar Integrante";
    ViewBag.Subtitle = Model.nombreInvestigador;
}

@section Styles {
    <style>
        /* Reutiliza los mismos estilos del formulario agregar */
        .form-card {
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 2px 16px rgba(0,0,0,.08);
            overflow: hidden;
            max-width: 720px;
            margin: 0 auto;
        }

        .form-card-header {
            background: linear-gradient(135deg,#0b2d24,#117a65);
            padding: 24px 30px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

            .form-card-header .hicon {
                width: 46px;
                height: 46px;
                background: rgba(255,255,255,.15);
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

                .form-card-header .hicon i {
                    font-size: 1.3rem;
                    color: #fff;
                }

            .form-card-header h4 {
                color: #fff;
                font-weight: 700;
                margin: 0;
                font-size: 1.05rem;
            }

            .form-card-header p {
                color: rgba(255,255,255,.65);
                font-size: .78rem;
                margin: 0;
            }

        .form-card-body {
            padding: 30px;
        }

        .form-label {
            font-size: .72rem;
            font-weight: 600;
            color: #117a65;
            text-transform: uppercase;
            letter-spacing: .5px;
            margin-bottom: 6px;
        }

        .input-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #aaa;
            font-size: .9rem;
            pointer-events: none;
            z-index: 2;
        }

        .form-control {
            padding: 10px 12px 10px 36px;
            border: 2px solid #dee2e6;
            border-radius: 10px;
            font-family: 'Poppins',sans-serif;
            font-size: .88rem;
            transition: border-color .25s,box-shadow .25s;
            width: 100%;
        }

            .form-control:focus {
                outline: none;
                border-color: #117a65;
                box-shadow: 0 0 0 3px rgba(17,122,101,.12);
            }

            .form-control.is-valid {
                border-color: #28b463 !important;
            }

            .form-control.is-invalid {
                border-color: #e74c3c !important;
            }

        .field-msg {
            font-size: .73rem;
            margin-top: 4px;
            min-height: 18px;
            display: block;
            padding-left: 2px;
        }

            .field-msg.error {
                color: #e74c3c;
            }

            .field-msg.ok {
                color: #28b463;
            }

        .form-select {
            padding: 10px 12px;
            border: 2px solid #dee2e6;
            border-radius: 10px;
            font-family: 'Poppins',sans-serif;
            font-size: .88rem;
            transition: border-color .25s;
            width: 100%;
        }

            .form-select:focus {
                outline: none;
                border-color: #117a65;
                box-shadow: 0 0 0 3px rgba(17,122,101,.12);
            }

            .form-select.is-valid {
                border-color: #28b463;
            }

            .form-select.is-invalid {
                border-color: #e74c3c;
            }

        .btn-guardar {
            background: linear-gradient(135deg,#0b2d24,#117a65);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 12px 32px;
            font-size: .92rem;
            font-weight: 600;
            font-family: 'Poppins',sans-serif;
            cursor: pointer;
            transition: opacity .2s;
        }

            .btn-guardar:hover {
                opacity: .88;
            }

        .btn-cancelar {
            background: #f0f4f8;
            color: #555;
            border: none;
            border-radius: 10px;
            padding: 12px 24px;
            font-size: .88rem;
            font-weight: 500;
            font-family: 'Poppins',sans-serif;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }

            .btn-cancelar:hover {
                background: #dee2e6;
                color: #333;
            }

        .section-divider {
            font-size: .7rem;
            font-weight: 700;
            color: #aaa;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid #f0f4f8;
            padding-bottom: 8px;
            margin-bottom: 18px;
        }
    </style>
}

<div class="form-card">
    <div class="form-card-header">
        <div class="hicon"><i class="fas fa-user-edit"></i></div>
        <div>
            <h4>Editar Integrante</h4>
            <p>Modificando datos de @Model.nombreInvestigador</p>
        </div>
    </div>

    <div class="form-card-body">
        @using (Html.BeginForm("EditarIntegrante", "LiderDashboard", FormMethod.Post,
                new { id = "formEditar", novalidate = "novalidate" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.idInvestigadores)
            @Html.HiddenFor(m => m.Usuario_idUsuario)

            <div class="section-divider">Datos Personales</div>
            <div class="row g-3 mb-3">
                <div class="col-md-12">
                    <label class="form-label">Nombre completo *</label>
                    <div class="input-wrap">
                        <span class="input-icon"><i class="fas fa-user"></i></span>
                        @Html.TextBoxFor(m => m.nombreInvestigador, new { @class = "form-control", id = "nombreInvestigador" })
                    </div>
                    <span class="field-msg" id="msg-nombre"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Correo electrónico *</label>
                    <div class="input-wrap">
                        <span class="input-icon"><i class="fas fa-envelope"></i></span>
                        @Html.TextBoxFor(m => m.emailInvestigador, new { @class = "form-control", id = "emailInvestigador" })
                    </div>
                    <span class="field-msg" id="msg-email"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Teléfono *</label>
                    <div class="input-wrap">
                        <span class="input-icon"><i class="fas fa-phone"></i></span>
                        @Html.TextBoxFor(m => m.telefonoInvestigador, new { @class = "form-control", id = "telefonoInvestigador", maxlength = "10" })
                    </div>
                    <span class="field-msg" id="msg-telefono"></span>
                </div>
            </div>

            <div class="section-divider">Clasificación</div>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label">Género *</label>
                    @Html.DropDownListFor(m => m.generoInvestigador,
                        ViewBag.Generos as List<SelectListItem>,
                        "-- Selecciona --",
                        new { @class = "form-select", id = "generoInvestigador" })
                    <span class="field-msg" id="msg-genero"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Tipo de Investigador *</label>
                    @Html.DropDownListFor(m => m.tipoInvestigador,
                        ViewBag.Tipos as List<SelectListItem>,
                        "-- Selecciona --",
                        new { @class = "form-select", id = "tipoInvestigador" })
                    <span class="field-msg" id="msg-tipo"></span>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-end">
                <a href="@Url.Action("Integrantes","LiderDashboard")" class="btn-cancelar">
                    <i class="fas fa-arrow-left me-2"></i>Cancelar
                </a>
                <button type="submit" class="btn-guardar" id="btnGuardar">
                    <i class="fas fa-save me-2"></i>Guardar Cambios
                </button>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
function setValid(id, msgId, txt)   { $('#'+id).removeClass('is-invalid').addClass('is-valid');   $('#'+msgId).removeClass('error').addClass('ok').text(txt||'✓ Correcto'); }
function setInvalid(id, msgId, txt) { $('#'+id).removeClass('is-valid').addClass('is-invalid');   $('#'+msgId).removeClass('ok').addClass('error').text(txt); }
function clearState(id, msgId)      { $('#'+id).removeClass('is-valid is-invalid'); $('#'+msgId).removeClass('ok error').text(''); }

$('#nombreInvestigador').on('input blur', function () {
    var v = $(this).val().trim();
    if (!v)               clearState('nombreInvestigador','msg-nombre');
    else if (v.length<3)  setInvalid('nombreInvestigador','msg-nombre','✗ Mínimo 3 caracteres');
    else if (!/^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s]+$/.test(v)) setInvalid('nombreInvestigador','msg-nombre','✗ Solo letras');
    else                  setValid('nombreInvestigador','msg-nombre','✓ Nombre válido');
});
$('#emailInvestigador').on('input blur', function () {
    var v = $(this).val().trim();
    if (!v)                              clearState('emailInvestigador','msg-email');
    else if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(v)) setInvalid('emailInvestigador','msg-email','✗ Email inválido');
    else                                 setValid('emailInvestigador','msg-email','✓ Email válido');
});
$('#telefonoInvestigador').on('input', function () {
    this.value = this.value.replace(/[^0-9]/g,'');
}).on('input blur', function () {
    var v = $(this).val().trim();
    if (!v)            clearState('telefonoInvestigador','msg-telefono');
    else if (v.length!==10) setInvalid('telefonoInvestigador','msg-telefono','✗ Exactamente 10 dígitos');
    else               setValid('telefonoInvestigador','msg-telefono','✓ Teléfono válido');
});
$('#generoInvestigador').on('change', function () {
    $(this).val() ? setValid('generoInvestigador','msg-genero','✓') : setInvalid('generoInvestigador','msg-genero','✗ Selecciona un género');
});
$('#tipoInvestigador').on('change', function () {
    $(this).val() ? setValid('tipoInvestigador','msg-tipo','✓') : setInvalid('tipoInvestigador','msg-tipo','✗ Selecciona un tipo');
});

$('#formEditar').on('submit', function (e) {
    ['#nombreInvestigador','#emailInvestigador','#telefonoInvestigador'].forEach(function(id){ $(id).trigger('blur'); });
    ['#generoInvestigador','#tipoInvestigador'].forEach(function(id){ $(id).trigger('change'); });
    if ($('.is-invalid').length > 0) {
        e.preventDefault();
        $('html,body').animate({ scrollTop: $('.is-invalid').first().offset().top - 100 }, 300);
    } else {
        $('#btnGuardar').prop('disabled',true).html('<i class="fas fa-spinner fa-spin me-2"></i>Guardando...');
    }
});
    </script>
}