@model IEnumerable<SemillerosApp.Models.Investigadores>
@{
    Layout = "~/Views/Shared/_LayoutLider.cshtml";
    ViewBag.Title = "Integrantes";
    ViewBag.Subtitle = "Semillero: " + ViewBag.NombreSemillero;
}

@section Styles {
    <style>
        .card-panel {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,.07);
            overflow: hidden;
        }

        .card-panel-header {
            padding: 16px 22px;
            border-bottom: 1px solid #f0f4f8;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .section-title {
            font-size: 1rem;
            font-weight: 600;
            color: #117a65;
            display: flex;
            align-items: center;
            gap: 8px;
            margin: 0;
        }

        .btn-primary-sm {
            background: linear-gradient(135deg,#0b2d24,#117a65);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 8px 18px;
            font-size: .82rem;
            font-family: 'Poppins',sans-serif;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: opacity .2s;
        }

            .btn-primary-sm:hover {
                opacity: .88;
                color: #fff;
            }

        .search-bar {
            padding: 16px 22px;
            border-bottom: 1px solid #f0f4f8;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .search-input {
            border: 2px solid #dee2e6;
            border-radius: 10px;
            padding: 8px 14px 8px 36px;
            font-family: 'Poppins',sans-serif;
            font-size: .85rem;
            width: 280px;
            transition: border-color .2s;
        }

            .search-input:focus {
                outline: none;
                border-color: #117a65;
            }

        .search-wrap {
            position: relative;
        }

            .search-wrap i {
                position: absolute;
                left: 11px;
                top: 50%;
                transform: translateY(-50%);
                color: #aaa;
            }

        table th {
            font-size: .72rem;
            text-transform: uppercase;
            color: #7f8c8d;
            font-weight: 600;
            border-bottom: 2px solid #f0f4f8;
            padding: 10px 12px;
        }

        table td {
            font-size: .83rem;
            vertical-align: middle;
            padding: 10px 12px;
        }

        table tr:hover td {
            background: #f0faf6;
        }

        .badge-tipo {
            font-size: .68rem;
            padding: 3px 10px;
            border-radius: 20px;
            font-weight: 600;
        }

        .badge-semillerista {
            background: #eaf4fb;
            color: #2e86c1;
        }

        .badge-auxiliar {
            background: #fef9e7;
            color: #d4ac0d;
        }

        .badge-asesor {
            background: #f4f0fb;
            color: #7d3c98;
        }

        .avatar-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg,#117a65,#28b463);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: .82rem;
            flex-shrink: 0;
        }

        .btn-sm-action {
            border: none;
            border-radius: 7px;
            padding: 5px 10px;
            font-size: .75rem;
            font-family: 'Poppins',sans-serif;
            cursor: pointer;
            transition: opacity .2s;
        }

            .btn-sm-action:hover {
                opacity: .8;
            }

        .btn-edit {
            background: #eaf4fb;
            color: #2e86c1;
        }

        .btn-delete {
            background: #fde8e8;
            color: #a93226;
        }

        .empty-state {
            text-align: center;
            padding: 48px 20px;
            color: #aaa;
        }

            .empty-state i {
                font-size: 2.5rem;
                margin-bottom: 12px;
                display: block;
            }
    </style>
}

<div class="card-panel">
    <div class="card-panel-header">
        <div class="section-title"><i class="fas fa-users"></i> Integrantes del Semillero</div>
        <a href="@Url.Action("AgregarIntegrante","LiderDashboard")" class="btn-primary-sm">
            <i class="fas fa-plus"></i> Agregar Integrante
        </a>
    </div>

    <div class="search-bar">
        <div class="search-wrap">
            <i class="fas fa-search"></i>
            <input type="text" id="buscador" class="search-input" placeholder="Buscar por nombre o email...">
        </div>
        <span style="font-size:.8rem;color:#aaa">@Model.Count() integrante(s)</span>
    </div>

    <div class="table-responsive">
        <table class="table mb-0" id="tablaIntegrantes">
            <thead>
                <tr>
                    <th class="ps-3">Integrante</th>
                    <th>Tipo</th>
                    <th>Email</th>
                    <th>Teléfono</th>
                    <th>Género</th>
                    <th class="pe-3">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in Model)
                {
                    <tr class="fila-integrante">
                        <td class="ps-3">
                            <div style="display:flex;align-items:center;gap:10px">
                                <div class="avatar-circle">@i.nombreInvestigador.Substring(0, 1).ToUpper()</div>
                                <strong>@i.nombreInvestigador</strong>
                            </div>
                        </td>
                        <td>
                            <span class="badge-tipo badge-@i.tipoInvestigador.ToLower()">
                                @i.tipoInvestigador
                            </span>
                        </td>
                        <td>@i.emailInvestigador</td>
                        <td>@i.telefonoInvestigador</td>
                        <td>@i.generoInvestigador</td>
                        <td class="pe-3">
                            <a href="@Url.Action("EditarIntegrante","LiderDashboard", new { id = i.idInvestigadores })"
                               class="btn-sm-action btn-edit me-1" title="Editar">
                                <i class="fas fa-edit"></i>
                            </a>
                            @using (Html.BeginForm("RetirarIntegrante", "LiderDashboard",
                                    new { id = i.idInvestigadores }, FormMethod.Post,
                                    new
                                    {
                                        style = "display:inline",
                                        onsubmit = $"return confirm('¿Retirar a {i.nombreInvestigador} del semillero?')"
                                    }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-sm-action btn-delete" title="Retirar">
                                    <i class="fas fa-user-minus"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="fas fa-users"></i>
                <p style="font-weight:600;color:#555">No hay integrantes registrados</p>
                <p style="font-size:.82rem">Agrega el primer integrante a tu semillero</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
// Buscador en tiempo real
$('#buscador').on('input', function () {
    var term = $(this).val().toLowerCase();
    $('.fila-integrante').each(function () {
        var texto = $(this).text().toLowerCase();
        $(this).toggle(texto.includes(term));
    });
});
    </script>
}