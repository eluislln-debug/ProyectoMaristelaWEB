@model SemillerosApp.Models.LiderDashboardViewModel
@{
    Layout = "~/Views/Shared/_LayoutLider.cshtml";
    ViewBag.Title = "Mi Semillero";
    ViewBag.Subtitle = Model.Semillero != null ? Model.Semillero.nombreSemillero : "Sin semillero asignado";
}

@section Styles {
    <style>
        .stat-card {
            background: #fff;
            border-radius: 16px;
            padding: 22px 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,.07);
            display: flex;
            align-items: center;
            gap: 18px;
            transition: transform .2s,box-shadow .2s;
        }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 24px rgba(0,0,0,.12);
            }

        .stat-icon {
            width: 56px;
            height: 56px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .stat-label {
            font-size: .75rem;
            color: #7f8c8d;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            color: #117a65;
            line-height: 1;
        }

        .card-panel {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,.07);
            overflow: hidden;
        }

        .card-panel-header {
            padding: 16px 22px;
            border-bottom: 1px solid #f0f4f8;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .section-title {
            font-size: 1rem;
            font-weight: 600;
            color: #117a65;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 0;
        }

        .badge-activo {
            background: #d5f5e3;
            color: #1e8449;
            font-size: .7rem;
            padding: 4px 10px;
            border-radius: 20px;
            font-weight: 600;
        }

        .badge-inactivo {
            background: #fde8e8;
            color: #a93226;
            font-size: .7rem;
            padding: 4px 10px;
            border-radius: 20px;
            font-weight: 600;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            padding: 20px 22px;
        }

        .info-item label {
            font-size: .7rem;
            color: #7f8c8d;
            text-transform: uppercase;
            letter-spacing: .5px;
            font-weight: 600;
            display: block;
        }

        .info-item span {
            font-size: .88rem;
            color: #2c3e50;
            font-weight: 500;
        }

        .btn-sm-action {
            border: none;
            border-radius: 7px;
            padding: 5px 11px;
            font-size: .75rem;
            font-family: 'Poppins',sans-serif;
            font-weight: 500;
            cursor: pointer;
            transition: opacity .2s;
        }

            .btn-sm-action:hover {
                opacity: .82;
            }

        .btn-primary-sm {
            background: linear-gradient(135deg,#117a65,#28b463);
            color: #fff;
            text-decoration: none;
            display: inline-block;
        }

        .table-integrantes th {
            font-size: .72rem;
            text-transform: uppercase;
            color: #7f8c8d;
            font-weight: 600;
        }

        .table-integrantes td {
            font-size: .83rem;
            vertical-align: middle;
            padding: 10px 12px;
        }

        .table-integrantes tr:hover td {
            background: #f0faf6;
        }

        .tab-btn {
            flex: 1;
            padding: 9px 12px;
            border: none;
            border-radius: 9px;
            background: transparent;
            font-family: 'Poppins',sans-serif;
            font-size: .8rem;
            font-weight: 500;
            color: #7f8c8d;
            cursor: pointer;
            transition: all .2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

            .tab-btn.active {
                background: #fff;
                color: #117a65;
                font-weight: 700;
                box-shadow: 0 2px 8px rgba(0,0,0,.08);
            }

            .tab-btn:hover:not(.active) {
                color: #117a65;
                background: rgba(255,255,255,.6);
            }

        .tab-pane {
            display: block;
        }

        .proyecto-card {
            border: 2px solid #f0f4f8;
            border-radius: 14px;
            padding: 18px 20px;
            margin-bottom: 14px;
            transition: border-color .2s,box-shadow .2s;
            background: #fff;
        }

            .proyecto-card:hover {
                border-color: #117a65;
                box-shadow: 0 4px 16px rgba(17,122,101,.1);
            }

        .proyecto-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 10px;
        }

        .proyecto-titulo {
            font-weight: 700;
            font-size: .95rem;
            color: #0b2d24;
        }

        .proyecto-desc {
            font-size: .8rem;
            color: #7f8c8d;
        }

        .proyecto-meta {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

            .proyecto-meta span {
                font-size: .75rem;
                color: #7f8c8d;
                display: flex;
                align-items: center;
                gap: 5px;
            }

        .fase-block {
            border: 2px solid #f0f4f8;
            border-radius: 12px;
            margin-top: 12px;
            overflow: hidden;
        }

        .fase-header {
            background: #f8fbff;
            padding: 10px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            transition: background .2s;
        }

            .fase-header:hover {
                background: #e8f8f2;
            }

        .fase-title {
            font-size: .85rem;
            font-weight: 600;
            color: #117a65;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .fase-body {
            padding: 14px 16px;
            border-top: 1px solid #f0f4f8;
            display: none;
        }

        .fase-chip {
            padding: 3px 10px;
            border-radius: 20px;
            font-size: .68rem;
            font-weight: 600;
        }

        .fase-completada {
            background: #d5f5e3;
            color: #1e8449;
        }

        .fase-en-proceso {
            background: #eaf4fb;
            color: #2e86c1;
        }

        .fase-pendiente {
            background: #fef9e7;
            color: #d4ac0d;
        }

        .actividad-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            border-radius: 8px;
            margin-bottom: 6px;
            background: #f8f9fa;
        }

        .actividad-nombre {
            font-size: .83rem;
            font-weight: 600;
            color: #2c3e50;
            flex: 1;
        }

        .actividad-meta {
            font-size: .72rem;
            color: #aaa;
        }

        .badge-proceso {
            background: #eaf4fb;
            color: #2e86c1;
            font-size: .7rem;
            padding: 4px 10px;
            border-radius: 20px;
            font-weight: 600;
        }

        .badge-finalizado {
            background: #d5f5e3;
            color: #1e8449;
            font-size: .7rem;
            padding: 4px 10px;
            border-radius: 20px;
            font-weight: 600;
        }

        .btn-xs {
            border: none;
            border-radius: 6px;
            padding: 4px 9px;
            font-size: .7rem;
            font-family: 'Poppins',sans-serif;
            cursor: pointer;
            transition: opacity .2s;
        }

            .btn-xs:hover {
                opacity: .8;
            }

        .btn-xs-success {
            background: #d5f5e3;
            color: #117a65;
        }

        .btn-xs-danger {
            background: #fde8e8;
            color: #a93226;
        }

        .btn-xs-info {
            background: #eaf4fb;
            color: #2e86c1;
        }

        .select-estado {
            border: 2px solid #dee2e6;
            border-radius: 8px;
            padding: 4px 8px;
            font-family: 'Poppins',sans-serif;
            font-size: .75rem;
            cursor: pointer;
        }

        .modal-input {
            border: 2px solid #dee2e6;
            border-radius: 10px;
            padding: 9px 14px;
            font-family: 'Poppins',sans-serif;
            font-size: .88rem;
            width: 100%;
            transition: border-color .2s;
        }

            .modal-input:focus {
                outline: none;
                border-color: #117a65;
                box-shadow: 0 0 0 3px rgba(17,122,101,.1);
            }

            .modal-input.is-invalid {
                border-color: #e74c3c;
            }

        .modal-label {
            font-size: .72rem;
            font-weight: 600;
            color: #117a65;
            text-transform: uppercase;
            letter-spacing: .4px;
            margin-bottom: 5px;
            display: block;
        }

        .field-err {
            font-size: .73rem;
            color: #e74c3c;
            margin-top: 3px;
            display: block;
            min-height: 16px;
        }

        .btn-modal-save {
            background: linear-gradient(135deg,#0b2d24,#117a65);
            color: #fff;
            border: none;
            border-radius: 9px;
            padding: 9px 22px;
            font-size: .85rem;
            font-weight: 600;
            font-family: 'Poppins',sans-serif;
            cursor: pointer;
        }

        .btn-modal-cancel {
            background: #f0f4f8;
            color: #555;
            border: none;
            border-radius: 9px;
            padding: 9px 18px;
            font-size: .85rem;
            font-family: 'Poppins',sans-serif;
            cursor: pointer;
        }
    </style>
}

@if (Model.Semillero == null)
{
    <div class="alert alert-warning" style="border-radius:14px">
        <i class="fas fa-exclamation-triangle me-2"></i>
        No tienes un semillero asignado. Contacta al administrador.
    </div>
}
else
{
    <!-- ── TARJETAS STATS ─────────────────────────────────────── -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon" style="background:#d5f5e3;color:#117a65"><i class="fas fa-users"></i></div>
                <div>
                    <div class="stat-label">Integrantes</div>
                    <div class="stat-value">@Model.TotalIntegrantes</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon" style="background:#eaf4fb;color:#2e86c1"><i class="fas fa-project-diagram"></i></div>
                <div>
                    <div class="stat-label">Proyectos</div>
                    <div class="stat-value" style="color:#2e86c1">@Model.TotalProyectos</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon" style="background:#fef9e7;color:#d4ac0d"><i class="fas fa-spinner"></i></div>
                <div>
                    <div class="stat-label">En Proceso</div>
                    <div class="stat-value" style="color:#d4ac0d">@Model.ProyectosActivos</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── INFO DEL SEMILLERO + GRÁFICAS ─────────────────────── -->
    <div class="row g-3 mb-4">
        <div class="col-md-5">
            <div class="card-panel h-100">
                <div class="card-panel-header">
                    <div class="section-title"><i class="fas fa-info-circle"></i> Información del Semillero</div>
                    <span class="@(Model.Semillero.estadoSemillero=="Activo" ? "badge-activo" : "badge-inactivo")">
                        @Model.Semillero.estadoSemillero
                    </span>
                </div>
                <div class="info-grid">
                    <div class="info-item">
                        <label>Nombre</label>
                        <span>@Model.Semillero.nombreSemillero</span>
                    </div>
                    <div class="info-item">
                        <label>Línea de Investigación</label>
                        <span>@Model.Semillero.lineaInvestigacion</span>
                    </div>
                    <div class="info-item">
                        <label>Líder</label>
                        <span>@Model.NombreLider</span>
                    </div>
                    <div class="info-item">
                        <label>Fecha de Creación</label>
                        <span>@Model.Semillero.fechacreaSemillero.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="info-item" style="grid-column:span 2">
                        <label>Descripción</label>
                        <span>@Model.Semillero.descripcionSemillero</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-panel h-100">
                <div class="card-panel-header">
                    <div class="section-title"><i class="fas fa-chart-pie"></i> Por Género</div>
                </div>
                <div style="padding:20px;height:220px;display:flex;align-items:center;justify-content:center">
                    <canvas id="chartGeneros"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card-panel h-100">
                <div class="card-panel-header">
                    <div class="section-title"><i class="fas fa-chart-bar"></i> Por Tipo</div>
                </div>
                <div style="padding:20px;height:220px;display:flex;align-items:center;justify-content:center">
                    <canvas id="chartTipos"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- ── TABS NAV ───────────────────────────────────────────── -->
    <div style="display:flex;gap:4px;background:#f0f4f8;border-radius:12px;padding:4px;margin-bottom:20px">
        <button class="tab-btn active" onclick="switchTab('tab-proyectos',this)">
            <i class="fas fa-project-diagram"></i> Proyectos (@Model.TotalProyectos)
        </button>
        <button class="tab-btn" onclick="switchTab('tab-integrantes',this)">
            <i class="fas fa-users"></i> Integrantes (@Model.TotalIntegrantes)
        </button>
    </div>

    <!-- ── TAB PROYECTOS ──────────────────────────────────────── -->
    <div id="tab-proyectos" class="tab-pane active">

        <div class="d-flex justify-content-end mb-3">
            <button type="button" class="btn-sm-action btn-primary-sm"
                    style="border:none;cursor:pointer"
                    data-bs-toggle="modal" data-bs-target="#modalCrearProyecto">
                <i class="fas fa-plus me-1"></i> Nuevo Proyecto
            </button>
        </div>

        @if (Model.Semillero.Proyectos != null && Model.Semillero.Proyectos.Any())
        {
            foreach (var p in Model.Semillero.Proyectos.OrderByDescending(x => x.fechainProyecto))
            {
                <div class="proyecto-card">
                    <div class="proyecto-header">
                        <div>
                            <div class="proyecto-titulo">
                                <i class="fas fa-folder-open me-2" style="color:#117a65;font-size:.85rem"></i>
                                @p.tituloProyecto
                            </div>
                            <div class="proyecto-desc">@p.descripcionProyecto</div>
                        </div>
                        <span class="@(p.estadoProyecto=="En Proceso" ? "badge-proceso"
                                 : p.estadoProyecto=="Finalizado"  ? "badge-finalizado"
                                 : "badge-inactivo")">
                            @p.estadoProyecto
                        </span>
                    </div>
                    <div class="proyecto-meta">
                        <span><i class="fas fa-calendar-plus"></i> @p.fechainProyecto.ToString("dd/MM/yyyy")</span>
                        <span><i class="fas fa-clock"></i> @p.duracionProyecto</span>
                        <span><i class="fas fa-layer-group"></i> @p.Fases.Count fase(s)</span>
                        <span><i class="fas fa-tasks"></i> @p.Fases.SelectMany(f => f.Actividades).Count() actividad(es)</span>
                    </div>

                    <!-- FASES -->
                    <div style="border-top:1px solid #f0f4f8;padding-top:12px;margin-top:8px">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
                            <span style="font-size:.7rem;color:#aaa;font-weight:700;text-transform:uppercase;letter-spacing:.5px">
                                Fases del proyecto
                            </span>
                            <button type="button" class="btn-xs btn-xs-info"
                                    data-bs-toggle="modal" data-bs-target="#modalCrearFase"
                                    onclick="setProyectoFase(@p.idProyecto, '@p.tituloProyecto')">
                                <i class="fas fa-plus me-1"></i>Nueva Fase
                            </button>
                        </div>

                        @foreach (var f in p.Fases.OrderBy(x => x.fechaFase))
                        {
                            string faseColor = f.estadoFase == "Completada" ? "#1e8449"
                                             : f.estadoFase == "En Proceso" ? "#117a65" : "#d4ac0d";
                            <div class="fase-block">
                                <div class="fase-header" onclick="toggleFase('fase-@f.idFase')">
                                    <div class="fase-title">
                                        <i class="fas fa-circle" style="font-size:.45rem;color:@faseColor"></i>
                                        @f.descripcionFase
                                        <span class="fase-chip @(f.estadoFase=="Completada"?"fase-completada":f.estadoFase=="En Proceso"?"fase-en-proceso":"fase-pendiente")">
                                            @f.estadoFase
                                        </span>
                                    </div>
                                    <div style="display:flex;align-items:center;gap:6px">
                                        @using (Html.BeginForm("EliminarFase", "LiderDashboard",
                                                new { idFase = f.idFase }, FormMethod.Post,
                                                new
                                                {
                                                    style = "display:inline",
                                                    onsubmit = "return confirm('¿Eliminar esta fase?')",
                                                    onclick = "event.stopPropagation()"
                                                }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-xs btn-xs-danger"
                                                    onclick="event.stopPropagation()">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        }
                                        <i class="fas fa-chevron-down" style="color:#aaa;font-size:.75rem"></i>
                                    </div>
                                </div>

                                <div class="fase-body" id="fase-@f.idFase">
                                    @foreach (var a in f.Actividades.OrderBy(x => x.fechaActividad))
                                    {
                                        <div class="actividad-item">
                                            <i class="fas fa-@(a.estadoActividad=="Completada"?"check-circle":"circle")"
                                               style="color:@(a.estadoActividad=="Completada"?"#28b463":"#dee2e6");font-size:.9rem"></i>
                                            <div style="flex:1">
                                                <div class="actividad-nombre">@a.nombreActividad</div>
                                                <div class="actividad-meta">
                                                    @a.descripActividad · <i class="fas fa-map-marker-alt me-1"></i>@a.lugarActividad
                                                </div>
                                            </div>
                                            @using (Html.BeginForm("CambiarEstadoActividad", "LiderDashboard",
                                                    new { idActividad = a.idActividad }, FormMethod.Post,
                                                    new { style = "display:inline" }))
                                            {
                                                @Html.AntiForgeryToken()
                                                <select name="nuevoEstado" class="select-estado"
                                                        onchange="this.form.submit()">
                                                    <option value="Pendiente" @(a.estadoActividad == "Pendiente" ? "selected" : "")>⏳ Pendiente</option>
                                                    <option value="En Proceso" @(a.estadoActividad == "En Proceso" ? "selected" : "")>🔄 En Proceso</option>
                                                    <option value="Completada" @(a.estadoActividad == "Completada" ? "selected" : "")>✅ Completada</option>
                                                </select>
                                            }
                                            @using (Html.BeginForm("EliminarActividad", "LiderDashboard",
                                                    new { idActividad = a.idActividad }, FormMethod.Post,
                                                    new
                                                    {
                                                        style = "display:inline",
                                                        onsubmit = "return confirm('¿Eliminar actividad?')"
                                                    }))
                                            {
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-xs btn-xs-danger">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    }
                                    <div style="margin-top:8px">
                                        <button type="button" class="btn-xs btn-xs-success"
                                                data-bs-toggle="modal" data-bs-target="#modalCrearActividad"
                                                onclick="setFaseActividad(@f.idFase, '@f.descripcionFase')">
                                            <i class="fas fa-plus me-1"></i>Nueva Actividad
                                        </button>
                                    </div>
                                    @if (!f.Actividades.Any())
                                    {
                                        <p style="font-size:.78rem;color:#aaa;text-align:center;padding:10px 0">
                                            Sin actividades. Agrega la primera.
                                        </p>
                                    }
                                </div>
                            </div>
                        }
                        @if (!p.Fases.Any())
                        {
                            <p style="font-size:.78rem;color:#aaa;text-align:center;padding:8px 0">
                                Sin fases. Agrega la primera.
                            </p>
                        }
                    </div>

                    <div style="margin-top:14px;display:flex;justify-content:flex-end">
                        @using (Html.BeginForm("EliminarProyecto", "LiderDashboard",
                                new { idProyecto = p.idProyecto }, FormMethod.Post,
                                new
                                {
                                    style = "display:inline",
                                    onsubmit = $"return confirm('¿Eliminar el proyecto {p.tituloProyecto}?')"
                                }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-xs btn-xs-danger">
                                <i class="fas fa-trash me-1"></i>Eliminar Proyecto
                            </button>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="card-panel" style="text-align:center;padding:36px;color:#bbb">
                <i class="fas fa-folder-open" style="font-size:2rem;display:block;margin-bottom:10px"></i>
                <p style="font-weight:600;color:#555">Sin proyectos aún</p>
                <p style="font-size:.85rem">Crea el primer proyecto con el botón de arriba.</p>
            </div>
        }
    </div>

    <!-- ── TAB INTEGRANTES ────────────────────────────────────── -->
    <div id="tab-integrantes" class="tab-pane" style="display:none">
        <div class="card-panel">
            <div class="card-panel-header">
                <div class="section-title"><i class="fas fa-users"></i> Integrantes del Semillero</div>
                <a href="@Url.Action("AgregarIntegrante","LiderDashboard")"
                   class="btn-sm-action btn-primary-sm">
                    <i class="fas fa-plus me-1"></i>Agregar Integrante
                </a>
            </div>
            <div class="p-0">
                <div class="table-responsive">
                    <table class="table table-integrantes mb-0">
                        <thead>
                            <tr>
                                <th class="ps-3">Nombre</th>
                                <th>Tipo</th>
                                <th>Email</th>
