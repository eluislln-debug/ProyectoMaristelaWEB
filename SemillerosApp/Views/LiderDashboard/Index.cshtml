@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
@if (Model.Semillero != null)
{
    <text>
    new Chart(document.getElementById('chartGeneros').getContext('2d'), {
        type: 'doughnut',
        data: {
            labels:   @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChartGeneros.Select(x => x.Label))),
            datasets: [{ data: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChartGeneros.Select(x => x.Value))),
                backgroundColor:['#28b463','#e74c3c','#f39c12'], borderWidth:2, borderColor:'#fff' }]
        },
        options:{ responsive:true, maintainAspectRatio:false,
                  plugins:{ legend:{ position:'bottom', labels:{ font:{ family:'Poppins', size:10 }}}}}
    });
    new Chart(document.getElementById('chartTipos').getContext('2d'), {
        type: 'bar',
        data: {
            labels:   @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChartTipos.Select(x => x.Label))),
            datasets: [{ data: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChartTipos.Select(x => x.Value))),
                backgroundColor:'rgba(17,122,101,.75)', borderRadius:8 }]
        },
        options:{ responsive:true, maintainAspectRatio:false,
                  plugins:{ legend:{ display:false }},
                  scales:{ y:{ beginAtZero:true, ticks:{ stepSize:1 }}, x:{ grid:{ display:false }}}}
    });
    </text>
}

// ── UTILIDADES ────────────────────────────────────────────
function switchTab(tabId, btn) {
    document.querySelectorAll('.tab-pane').forEach(function (p) {
        p.classList.remove('active');
        p.style.display = 'none';
    });
    document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
    document.getElementById(tabId).classList.add('active');
    document.getElementById(tabId).style.display = 'block';
    btn.classList.add('active');
}
function toggleFase(id) {
    var el = document.getElementById(id);
    el.style.display = el.style.display === 'block' ? 'none' : 'block';
}
function setError(inputId, errId, msg) {
    var el = document.getElementById(inputId);
    if (el) { el.classList.add('is-invalid'); el.style.borderColor = '#e74c3c'; }
    var err = document.getElementById(errId);
    if (err) err.innerText = msg;
}
function clearError(inputId, errId) {
    var el = document.getElementById(inputId);
    if (el) { el.classList.remove('is-invalid'); el.style.borderColor = ''; }
    var err = document.getElementById(errId);
    if (err) err.innerText = '';
}
function validarCampo(id, errId, min, msg) {
    var v = document.getElementById(id).value.trim();
    if (v.length < min) {
        document.getElementById(id).classList.add('is-invalid');
        document.getElementById(errId).innerText = msg;
        return false;
    }
    document.getElementById(id).classList.remove('is-invalid');
    document.getElementById(errId).innerText = '';
    return true;
}

// ── MODAL PROYECTO ────────────────────────────────────────
document.getElementById('mp-titulo').addEventListener('input', function () { validarCampo('mp-titulo', 'err-mp-titulo', 3, 'Mínimo 3 caracteres'); });
document.getElementById('mp-desc').addEventListener('input',  function () { validarCampo('mp-desc',   'err-mp-desc',   5, 'Mínimo 5 caracteres'); });
document.getElementById('mp-dur').addEventListener('input',   function () { validarCampo('mp-dur',    'err-mp-dur',    2, 'Mínimo 2 caracteres'); });
document.getElementById('formProyecto').addEventListener('submit', function (e) {
    var ok = true;
    if (!validarCampo('mp-titulo', 'err-mp-titulo', 3, 'Mínimo 3 caracteres')) ok = false;
    if (!validarCampo('mp-desc',   'err-mp-desc',   5, 'Mínimo 5 caracteres')) ok = false;
    if (!validarCampo('mp-dur',    'err-mp-dur',    2, 'Mínimo 2 caracteres')) ok = false;
    if (!ok) { e.preventDefault(); return; }
    document.getElementById('btnCrearProyecto').disabled = true;
});

// ── MODAL FASE ────────────────────────────────────────────
function setProyectoFase(idProyecto, nombre) {
    document.getElementById('fase-idProyecto').value = idProyecto;
    document.getElementById('fase-proyectoNombre').innerText = nombre;
    document.getElementById('mf-desc').value = '';
    document.getElementById('mf-desc').classList.remove('is-invalid');
    document.getElementById('err-mf-desc').innerText = '';
    document.getElementById('mf-fechaLimite').value = '';
    clearError('mf-fechaLimite', 'err-mf-fechaLimite');
}
document.getElementById('mf-desc').addEventListener('input', function () {
    validarCampo('mf-desc', 'err-mf-desc', 3, 'Mínimo 3 caracteres');
});
document.getElementById('mf-fechaLimite').addEventListener('change', function () {
    var hoy = new Date().toISOString().split('T')[0];
    if (this.value && this.value < hoy) {
        setError('mf-fechaLimite', 'err-mf-fechaLimite', 'La fecha límite no puede ser en el pasado');
    } else {
        clearError('mf-fechaLimite', 'err-mf-fechaLimite');
    }
});
document.getElementById('formFase').addEventListener('submit', function (e) {
    var ok = true;
    if (!validarCampo('mf-desc', 'err-mf-desc', 3, 'Mínimo 3 caracteres')) ok = false;
    var fechaLimite = document.getElementById('mf-fechaLimite').value;
    var hoy = new Date().toISOString().split('T')[0];
    if (fechaLimite && fechaLimite < hoy) {
        setError('mf-fechaLimite', 'err-mf-fechaLimite', 'La fecha límite no puede ser en el pasado');
        ok = false;
    }
    if (!ok) e.preventDefault();
});

// ── MODAL ACTIVIDAD ───────────────────────────────────────
function setFaseActividad(idFase, nombre) {
    document.getElementById('act-idFase').value = idFase;
    document.getElementById('act-faseNombre').innerText = nombre;
    ['ma-nombre', 'ma-desc', 'ma-lugar', 'ma-fecha'].forEach(function (id) {
        document.getElementById(id).value = '';
        document.getElementById(id).classList.remove('is-invalid');
        document.getElementById(id).style.borderColor = '';
    });
    ['err-ma-nombre', 'err-ma-desc', 'err-ma-lugar', 'err-ma-fecha'].forEach(function (id) {
        document.getElementById(id).innerText = '';
    });
    document.querySelector('[name="horaActividad"]').value = '';
    document.getElementById('ma-flimite').value = '';
    document.querySelector('[name="horaLimiteActividad"]').value = '';
    clearError('ma-flimite', 'err-ma-flimite');
}
function validarFechasActividad() {
    var fechaInicio = document.getElementById('ma-fecha').value;
    var horaInicio  = document.querySelector('[name="horaActividad"]').value;
    var fechaLimite = document.getElementById('ma-flimite').value;
    var horaLimite  = document.querySelector('[name="horaLimiteActividad"]').value;
    var ahora       = new Date();
    var hoy         = ahora.toISOString().split('T')[0];
    var horaActual  = ahora.getHours().toString().padStart(2,'0') + ':' + ahora.getMinutes().toString().padStart(2,'0');
    var ok = true;

    // Fecha inicio requerida y no puede ser en el pasado
    if (!fechaInicio) {
        setError('ma-fecha', 'err-ma-fecha', 'La fecha de inicio es requerida');
        ok = false;
    } else if (fechaInicio < hoy) {
        setError('ma-fecha', 'err-ma-fecha', 'La fecha de inicio no puede ser en el pasado');
        ok = false;
    } else {
        clearError('ma-fecha', 'err-ma-fecha');
    }

    // Si es hoy, la hora debe ser posterior a la actual
    if (fechaInicio === hoy && horaInicio && horaInicio <= horaActual) {
        setError('ma-fecha', 'err-ma-fecha', 'La hora de inicio debe ser posterior a la hora actual (' + horaActual + ')');
        ok = false;
    }

    // Fecha límite: mínimo 1 hora después del inicio
    if (fechaInicio && fechaLimite) {
        var dtInicio = new Date(fechaInicio + 'T' + (horaInicio || '00:00'));
        var dtLimite = new Date(fechaLimite + 'T' + (horaLimite || '23:59'));
        var diffMinutos = (dtLimite - dtInicio) / (1000 * 60);
        if (dtLimite <= dtInicio) {
            setError('ma-flimite', 'err-ma-flimite', 'La fecha/hora límite debe ser posterior a la de inicio');
            ok = false;
        } else if (diffMinutos < 60) {
            setError('ma-flimite', 'err-ma-flimite', 'La fecha/hora límite debe ser al menos 1 hora después del inicio');
            ok = false;
        } else {
            clearError('ma-flimite', 'err-ma-flimite');
        }
    } else {
        clearError('ma-flimite', 'err-ma-flimite');
    }
    return ok;
}
['ma-nombre', 'ma-desc', 'ma-lugar'].forEach(function (id) {
    document.getElementById(id).addEventListener('input', function () {
        validarCampo(id, 'err-' + id, 3, 'Mínimo 3 caracteres');
    });
});
document.getElementById('ma-fecha').addEventListener('change', function () {
    if (document.getElementById('ma-flimite').value) validarFechasActividad();
    else {
        var ahora = new Date();
        var hoy = ahora.toISOString().split('T')[0];
        if (this.value && this.value < hoy) {
            setError('ma-fecha', 'err-ma-fecha', 'La fecha de inicio no puede ser en el pasado');
        } else {
            clearError('ma-fecha', 'err-ma-fecha');
        }
    }
});
document.getElementById('ma-flimite').addEventListener('change', validarFechasActividad);
document.querySelector('[name="horaActividad"]').addEventListener('change', function () {
    if (document.getElementById('ma-fecha').value) validarFechasActividad();
});
document.querySelector('[name="horaLimiteActividad"]').addEventListener('change', function () {
    if (document.getElementById('ma-flimite').value) validarFechasActividad();
});
document.getElementById('formActividad').addEventListener('submit', function (e) {
    var ok = true;
    if (!validarCampo('ma-nombre', 'err-ma-nombre', 3, 'Mínimo 3 caracteres')) ok = false;
    if (!validarCampo('ma-desc',   'err-ma-desc',   3, 'Mínimo 3 caracteres')) ok = false;
    if (!validarCampo('ma-lugar',  'err-ma-lugar',  3, 'Mínimo 3 caracteres')) ok = false;
    if (!validarFechasActividad()) ok = false;
    if (!ok) e.preventDefault();
});
    </script>
}
