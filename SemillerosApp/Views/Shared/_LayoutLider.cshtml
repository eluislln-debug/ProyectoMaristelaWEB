@{
    var userData = (User.Identity as System.Web.Security.FormsIdentity)?.Ticket.UserData ?? "";
    var partes = userData.Split('|');
    var nombreLider = partes.Length >= 2 ? partes[1] : "Líder";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Panel Líder</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --primary: #1a5276;
            --secondary: #2e86c1;
            --accent: #28b463;
            --lider: #117a65; /* verde oscuro — color distintivo del líder */
            --sidebar-w: 260px;
            --top-h: 64px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: #f0f4f8;
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: var(--sidebar-w);
            background: linear-gradient(180deg, #0b2d24 0%, var(--lider) 100%);
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            z-index: 1000;
        }

        .sidebar-brand {
            padding: 22px 20px;
            border-bottom: 1px solid rgba(255,255,255,.1);
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .sidebar-brand .brand-icon {
                width: 42px;
                height: 42px;
                background: linear-gradient(135deg,#28b463,#1abc9c);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

                .sidebar-brand .brand-icon i {
                    font-size: 20px;
                    color: #fff;
                }

            .sidebar-brand span {
                color: #fff;
                font-weight: 700;
                font-size: .95rem;
                line-height: 1.2;
            }

            .sidebar-brand small {
                color: rgba(255,255,255,.55);
                font-size: .7rem;
                display: block;
            }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 14px 0;
        }

        .nav-section-title {
            color: rgba(255,255,255,.35);
            font-size: .64rem;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 12px 22px 6px;
        }

        .nav-item a {
            display: flex;
            align-items: center;
            gap: 12px;
            color: rgba(255,255,255,.7);
            text-decoration: none;
            padding: 10px 22px;
            font-size: .85rem;
            transition: background .2s, color .2s;
            position: relative;
        }

            .nav-item a i {
                width: 18px;
                text-align: center;
                font-size: .9rem;
            }

            .nav-item a:hover {
                background: rgba(255,255,255,.08);
                color: #fff;
            }

            .nav-item a.active {
                background: linear-gradient(90deg, rgba(40,180,99,.35), transparent);
                color: #fff;
                font-weight: 600;
            }

                .nav-item a.active::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 0;
                    bottom: 0;
                    width: 3px;
                    background: #28b463;
                    border-radius: 0 3px 3px 0;
                }

        .sidebar-footer {
            padding: 16px 20px;
            border-top: 1px solid rgba(255,255,255,.1);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg,#28b463,#1abc9c);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: .85rem;
            flex-shrink: 0;
        }

        .user-name {
            color: #fff;
            font-size: .8rem;
            font-weight: 600;
        }

        .user-role {
            color: rgba(255,255,255,.45);
            font-size: .68rem;
        }

        .main-wrap {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            height: var(--top-h);
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            box-shadow: 0 2px 8px rgba(0,0,0,.07);
            position: sticky;
            top: 0;
            z-index: 500;
        }

        .topbar-title {
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--lider);
        }

            .topbar-title small {
                font-size: .75rem;
                color: #7f8c8d;
                display: block;
                font-weight: 400;
            }

        .btn-logout {
            background: linear-gradient(135deg,#e74c3c,#c0392b);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 7px 16px;
            font-size: .8rem;
            font-family: 'Poppins',sans-serif;
            font-weight: 500;
            cursor: pointer;
            transition: opacity .2s;
        }

            .btn-logout:hover {
                opacity: .88;
            }

        .content {
            padding: 28px;
            flex: 1;
        }

        .toast-container {
            position: fixed;
            top: 80px;
            right: 22px;
            z-index: 9999;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon"><i class="fas fa-seedling"></i></div>
            <div>
                <span>SemillerosApp</span>
                <small>Panel del Líder</small>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-title">Principal</div>
            <div class="nav-item">
                <a href="@Url.Action("Index","LiderDashboard")"
                   class="@(currentAction=="Index" ? "active" : "")">
                    <i class="fas fa-th-large"></i> Mi Semillero
                </a>
            </div>

            <div class="nav-section-title">Gestión</div>
            <div class="nav-item">
                <a href="@Url.Action("Integrantes","LiderDashboard")"
                   class="@(currentAction=="Integrantes" || currentAction=="AgregarIntegrante" || currentAction=="EditarIntegrante" ? "active" : "")">
                    <i class="fas fa-users"></i> Integrantes
                </a>
            </div>
            <div class="nav-item">
                <a href="@Url.Action("Reuniones","LiderDashboard")"
                   class="@(currentAction=="Reuniones" || currentAction=="CrearReunion" || currentAction=="EditarReunion" ? "active" : "")">
                    <i class="fas fa-handshake"></i> Reuniones
                </a>
            </div>
            <div class="nav-item">
                <a href="@Url.Action("Eventos","LiderDashboard")"
                   class="@(ViewContext.RouteData.Values["action"].ToString() == "Eventos" ? "active" : "")">
                    <i class="fas fa-star"></i>Eventos
                </a>
            </div>

            <div class="nav-section-title">Asistente IA</div>
            <div class="nav-item">
                <a href="@Url.Action("Index","Asistente")"
                   class="@(currentController=="Asistente" ? "active" : "")">
                    <i class="fas fa-robot"></i> Asistente IA
                </a>
            </div>

            <div class="nav-section-title">Cuenta</div>
            <div class="nav-item">
                <a href="@Url.Action("MiPerfil","LiderDashboard")"
                   class="@(currentAction=="MiPerfil" ? "active" : "")">
                    <i class="fas fa-user-circle"></i> Mi Perfil
                </a>
            </div>
        </nav>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">@nombreLider.Substring(0, 1).ToUpper()</div>
                <div>
                    <div class="user-name">@nombreLider</div>
                    <div class="user-role">Líder de Semillero</div>
                </div>
            </div>
            <button type="button" class="btn-logout w-100" onclick="confirmarLogout()">
                <i class="fas fa-sign-out-alt me-2"></i>Cerrar Sesión
            </button>
        </div>
    </aside>

    <div class="main-wrap">
        <header class="topbar">
            <div class="topbar-title">
                @ViewBag.Title
                <small>@ViewBag.Subtitle</small>
            </div>
            <div class="topbar-right" style="display:flex;align-items:center;gap:14px">
                <span style="font-size:.8rem;color:#7f8c8d">
                    <i class="fas fa-calendar-alt me-1"></i>
                    @DateTime.Now.ToString("dd/MM/yyyy")
                </span>
            </div>
        </header>

        @if (TempData["Mensaje"] != null)
        {
            <div class="toast-container">
                <div class="toast show align-items-center text-white
                         bg-@(TempData["TipoMensaje"]?.ToString() == "success" ? "success" : "warning")"
                     role="alert">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="fas fa-@(TempData["TipoMensaje"]?.ToString() == "success" ? "check-circle" : "exclamation-triangle") me-2"></i>
                            @TempData["Mensaje"]
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto"
                                data-bs-dismiss="toast"></button>
                    </div>
                </div>
            </div>
        }

        <main class="content">
            @RenderBody()
        </main>
    </div>

    <!-- Modal Logout -->
    <div class="modal fade" id="modalLogout" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px">
            <div class="modal-content" style="border-radius:18px;border:none;overflow:hidden">
                <div class="modal-body text-center p-4">
                    <div style="width:64px;height:64px;background:#fde8e8;border-radius:50%;
                            display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
                        <i class="fas fa-sign-out-alt" style="font-size:1.6rem;color:#e74c3c"></i>
                    </div>
                    <h5 style="font-weight:700;color:#117a65;margin-bottom:8px">¿Cerrar sesión?</h5>
                    <p style="font-size:.85rem;color:#7f8c8d;margin-bottom:24px">
                        Tu sesión activa se cerrará. Tendrás que volver a iniciar sesión para acceder al sistema.
                    </p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="button"
                                style="border:2px solid #dee2e6;background:#fff;border-radius:10px;
                                   padding:9px 24px;font-size:.85rem;font-family:'Poppins',sans-serif;
                                   font-weight:500;color:#555;cursor:pointer"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        @using (Html.BeginForm("Logout", "Account", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    style="background:linear-gradient(135deg,#e74c3c,#c0392b);color:#fff;
                                       border:none;border-radius:10px;padding:9px 24px;font-size:.85rem;
                                       font-family:'Poppins',sans-serif;font-weight:600;cursor:pointer">
                                <i class="fas fa-sign-out-alt me-2"></i>Sí, cerrar sesión
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function confirmarLogout() {
            new bootstrap.Modal(document.getElementById('modalLogout')).show();
        }
        var toastEl = document.querySelector('.toast');
        if (toastEl) {
            setTimeout(function () { bootstrap.Toast.getOrCreateInstance(toastEl).hide(); }, 4000);
        }
    </script>
    @RenderSection("Scripts", required: false)
    <!-- ── ASISTENTE FLOTANTE ── -->
    <div id="chatFloatContainer" style="position:fixed;bottom:24px;right:24px;z-index:9998;display:flex;flex-direction:column;align-items:flex-end;gap:10px;">
        <div id="chatFloatBox" style="display:none;width:340px;background:#fff;border-radius:18px;box-shadow:0 16px 50px rgba(0,0,0,.18);flex-direction:column;">
            <div style="background:linear-gradient(135deg,#0b2d24,#117a65);padding:14px 16px;display:flex;align-items:center;justify-content:space-between;border-radius:18px 18px 0 0;">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:34px;height:34px;background:rgba(255,255,255,.2);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                        <i class="fas fa-robot" style="color:#fff;font-size:.95rem;"></i>
                    </div>
                    <div>
                        <p style="margin:0;font-size:.82rem;font-weight:700;color:#fff;">Asistente IA</p>
                        <span style="font-size:.65rem;color:rgba(255,255,255,.7);">LLaMA 3 · Semilleros</span>
                    </div>
                </div>
                <div style="display:flex;gap:8px;">
                    <a href="@Url.Action("Index","Asistente")" title="Pantalla completa"
                       style="width:28px;height:28px;background:rgba(255,255,255,.15);border-radius:7px;display:flex;align-items:center;justify-content:center;color:#fff;text-decoration:none;">
                        <i class="fas fa-expand-alt" style="font-size:.75rem;"></i>
                    </a>
                    <button onclick="cerrarChat()" style="width:28px;height:28px;background:rgba(255,255,255,.15);border:none;border-radius:7px;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                        <i class="fas fa-times" style="font-size:.75rem;"></i>
                    </button>
                </div>
            </div>
            <div id="floatMsgs" style="height:280px;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:10px;background:#f8fafc;">
                <div style="display:flex;gap:8px;align-items:flex-start;">
                    <div style="width:28px;height:28px;background:linear-gradient(135deg,#28b463,#1abc9c);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="fas fa-robot" style="color:#fff;font-size:.7rem;"></i>
                    </div>
                    <div style="background:#fff;padding:9px 12px;border-radius:4px 12px 12px 12px;font-size:.78rem;color:#333;max-width:80%;box-shadow:0 1px 4px rgba(0,0,0,.06);">
                        ¡Hola! ¿En qué te puedo ayudar con tu semillero?
                    </div>
                </div>
            </div>
            <div style="padding:10px 12px;border-top:1px solid #f0f4f8;display:flex;gap:8px;background:#fff;border-radius:0 0 18px 18px;">
                <input type="text" id="floatInput" placeholder="Escribe aquí..."
                       style="flex:1;padding:8px 12px;border:2px solid #dee2e6;border-radius:9px;font-family:'Poppins',sans-serif;font-size:.78rem;outline:none;transition:border-color .2s;"
                       onkeydown="if(event.key==='Enter') enviarFlotante()"
                       onfocus="this.style.borderColor='#28b463'"
                       onblur="this.style.borderColor='#dee2e6'" />
                <button onclick="enviarFlotante()"
                        style="width:36px;height:36px;background:linear-gradient(135deg,#0b2d24,#117a65);border:none;border-radius:9px;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="fas fa-paper-plane" style="font-size:.75rem;"></i>
                </button>
            </div>
        </div>
        <button onclick="toggleChat()" id="fabBtn"
                style="width:54px;height:54px;background:linear-gradient(135deg,#0b2d24,#117a65);border:none;border-radius:50%;color:#fff;font-size:1.2rem;cursor:pointer;box-shadow:0 6px 22px rgba(17,122,101,.45);display:flex;align-items:center;justify-content:center;transition:transform .2s;"
                onmouseover="this.style.transform='scale(1.1)'"
                onmouseout="this.style.transform='scale(1)'">
            <i class="fas fa-robot" id="fabIcon"></i>
        </button>
    </div>

    @Html.AntiForgeryToken()

    <script>
    var chatAbierto = false;
    var floatEnviando = false;
    function abrirChat() {
        chatAbierto = true;
        document.getElementById('chatFloatBox').style.display = 'flex';
        document.getElementById('fabIcon').className = 'fas fa-times';
        document.getElementById('floatInput').focus();
    }
    function cerrarChat() {
        chatAbierto = false;
        document.getElementById('chatFloatBox').style.display = 'none';
        document.getElementById('fabIcon').className = 'fas fa-robot';
    }
    function toggleChat() {
        if (chatAbierto) { cerrarChat(); } else { abrirChat(); }
    }
    function agregarMsgFlotante(tipo, texto) {
        var box = document.getElementById('floatMsgs');
        var isIA = tipo === 'ia';
        var wrap = document.createElement('div');
        wrap.style.cssText = 'display:flex;gap:8px;align-items:flex-start;' + (isIA ? '' : 'flex-direction:row-reverse;');
        var colorAvatar = isIA ? 'linear-gradient(135deg,#28b463,#1abc9c)' : 'linear-gradient(135deg,#0b2d24,#117a65)';
        var bBg = isIA ? '#fff' : 'linear-gradient(135deg,#0b2d24,#117a65)';
        var bColor = isIA ? '#333' : '#fff';
        var bRadius = isIA ? '4px 12px 12px 12px' : '12px 4px 12px 12px';
        wrap.innerHTML =
            '<div style="width:28px;height:28px;background:' + colorAvatar + ';border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">' +
                '<i class="fas fa-' + (isIA ? 'robot' : 'user') + '" style="color:#fff;font-size:.7rem;"></i>' +
            '</div>' +
            '<div style="background:' + bBg + ';color:' + bColor + ';padding:9px 12px;border-radius:' + bRadius + ';font-size:.78rem;max-width:80%;box-shadow:0 1px 4px rgba(0,0,0,.06);word-break:break-word;line-height:1.5;">' +
                texto.replace(/\n/g, '<br>') +
            '</div>';
        box.appendChild(wrap);
        box.scrollTop = box.scrollHeight;
    }
    function mostrarTypingFlotante() {
        var box = document.getElementById('floatMsgs');
        var div = document.createElement('div');
        div.id = 'floatTyping';
        div.style.cssText = 'display:flex;gap:8px;align-items:flex-start;';
        div.innerHTML =
            '<div style="width:28px;height:28px;background:linear-gradient(135deg,#28b463,#1abc9c);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">' +
                '<i class="fas fa-robot" style="color:#fff;font-size:.7rem;"></i>' +
            '</div>' +
            '<div style="background:#fff;padding:10px 14px;border-radius:4px 12px 12px 12px;box-shadow:0 1px 4px rgba(0,0,0,.06);display:flex;gap:5px;align-items:center;">' +
                '<div style="width:7px;height:7px;background:#aaa;border-radius:50%;animation:floatBounce .9s infinite;"></div>' +
                '<div style="width:7px;height:7px;background:#aaa;border-radius:50%;animation:floatBounce .9s infinite;animation-delay:.2s;"></div>' +
                '<div style="width:7px;height:7px;background:#aaa;border-radius:50%;animation:floatBounce .9s infinite;animation-delay:.4s;"></div>' +
            '</div>';
        box.appendChild(div);
        box.scrollTop = box.scrollHeight;
    }
    function enviarFlotante() {
        if (floatEnviando) return;
        var input = document.getElementById('floatInput');
        var mensaje = input.value.trim();
        if (!mensaje) return;
        floatEnviando = true;
        input.value = '';
        agregarMsgFlotante('user', mensaje);
        mostrarTypingFlotante();
        $.ajax({
            url: '@Url.Action("Preguntar","Asistente")',
            method: 'POST',
            data: {
                mensaje: mensaje,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').first().val()
            },
            success: function (r) {
                var t = document.getElementById('floatTyping');
                if (t) { t.remove(); }
                agregarMsgFlotante('ia', r.respuesta || ('⚠️ ' + (r.error || 'Error desconocido')));
            },
            error: function () {
                var t = document.getElementById('floatTyping');
                if (t) { t.remove(); }
                agregarMsgFlotante('ia', '⚠️ No se pudo conectar con el asistente.');
            },
            complete: function () { floatEnviando = false; }
        });
    }
    </script>

    <style>
        @@keyframes floatBounce {
            0%, 60%, 100% {
                transform: translateY(0);
            }

            30% {
                transform: translateY(-7px);
            }
        }
    </style>
</body>
</html>