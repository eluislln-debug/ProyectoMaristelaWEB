@model SemillerosApp.Models.AdminDashboardViewModel
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewBag.Title = "Dashboard";
    ViewBag.Subtitle = "Visión general del sistema";
}

@section Styles {
    <style>
        .stat-card {
            background: #fff;
            border-radius: 16px;
            padding: 22px 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,.07);
            display: flex;
            align-items: center;
            gap: 18px;
            transition: transform .2s, box-shadow .2s;
        }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 24px rgba(0,0,0,.12);
            }

        /* Estilo para el botón de reportes */
        .btn-reporte-card {
            background: linear-gradient(135deg, #1a5276, #2e86c1);
            color: #fff;
            border-radius: 16px;
            padding: 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            text-decoration: none;
            transition: transform .2s, box-shadow .2s;
            box-shadow: 0 4px 15px rgba(26,82,118,0.2);
            margin-bottom: 24px;
        }

            .btn-reporte-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 25px rgba(26,82,118,0.3);
                color: #fff;
            }

            .btn-reporte-card h4 {
                margin: 0;
                font-size: 1.3rem;
                font-weight: 600;
            }

            .btn-reporte-card p {
                margin: 4px 0 0;
                opacity: 0.8;
                font-size: 0.9rem;
            }

        .stat-icon {
            width: 56px;
            height: 56px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .stat-label {
            font-size: .75rem;
            color: #7f8c8d;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            color: #1a5276;
            line-height: 1;
        }

        .stat-sub {
            font-size: .72rem;
            color: #95a5a6;
            margin-top: 2px;
        }

        .section-title {
            font-size: 1rem;
            font-weight: 600;
            color: #1a5276;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .section-title i {
                color: #2e86c1;
            }

        .card-panel {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,.07);
            overflow: hidden;
        }

        .card-panel-header {
            padding: 16px 22px;
            border-bottom: 1px solid #f0f4f8;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-panel-body {
            padding: 20px 22px;
        }
    </style>
}

<a href="@Url.Action("Index", "Reporte")" class="btn-reporte-card">
    <div>
        <h4>Panel de Reportes</h4>
        <p>Visualizar estadísticas detalladas y exportación de datos del sistema.</p>
    </div>
    <i class="fas fa-file-export" style="font-size: 3rem; opacity: 0.3;"></i>
</a>

<div class="row g-3 mb-4">
    <div class="col-xl-4 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#eaf4fb;color:#2e86c1"><i class="fas fa-leaf"></i></div>
            <div>
                <div class="stat-label">Total Semilleros</div>
                <div class="stat-value">@Model.TotalSemilleros</div>
                <div class="stat-sub">@Model.SemillerosActivos activos · @Model.SemillerosInactivos inactivos</div>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fef9e7;color:#d4ac0d"><i class="fas fa-users"></i></div>
            <div>
                <div class="stat-label">Investigadores</div>
                <div class="stat-value" style="color:#d4ac0d">@Model.TotalInvestigadores</div>
                <div class="stat-sub">Registrados en el sistema</div>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#f4f0fb;color:#7d3c98"><i class="fas fa-user-shield"></i></div>
            <div>
                <div class="stat-label">Usuarios</div>
                <div class="stat-value" style="color:#7d3c98">@Model.TotalUsuarios</div>
                <div class="stat-sub">Cuentas activas</div>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fef5ec;color:#ca6f1e"><i class="fas fa-project-diagram"></i></div>
            <div>
                <div class="stat-label">Proyectos</div>
                <div class="stat-value" style="color:#ca6f1e">@Model.TotalProyectos</div>
                <div class="stat-sub">En todos los semilleros</div>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#d5f5e3;color:#1e8449"><i class="fas fa-check-circle"></i></div>
            <div>
                <div class="stat-label">Semilleros Activos</div>
                <div class="stat-value" style="color:#1e8449">@Model.SemillerosActivos</div>
                <div class="stat-sub">Funcionando actualmente</div>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fde8e8;color:#a93226"><i class="fas fa-pause-circle"></i></div>
            <div>
                <div class="stat-label">Semilleros Inactivos</div>
                <div class="stat-value" style="color:#a93226">@Model.SemillerosInactivos</div>
                <div class="stat-sub">Pausados o cerrados</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-5">
        <div class="card-panel">
            <div class="card-panel-header">
                <div class="section-title mb-0"><i class="fas fa-chart-pie"></i> Semilleros por Estado</div>
            </div>
            <div class="card-panel-body" style="height:240px;display:flex;align-items:center;justify-content:center">
                <canvas id="chartEstados"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card-panel">
            <div class="card-panel-header">
                <div class="section-title mb-0"><i class="fas fa-chart-bar"></i> Semilleros por Línea de Investigación</div>
            </div>
            <div class="card-panel-body" style="height:240px">
                <canvas id="chartLineas"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        var ctxE = document.getElementById('chartEstados').getContext('2d');
        new Chart(ctxE, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChartEstados.Select(x => x.Label))),
                datasets: [{ data: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChartEstados.Select(x => x.Value))),
                    backgroundColor: ['#28b463','#e74c3c','#f39c12','#3498db'], borderWidth: 2, borderColor: '#fff' }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
        });

        var ctxL = document.getElementById('chartLineas').getContext('2d');
        new Chart(ctxL, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChartLineas.Select(x => x.Label))),
                datasets: [{ label: 'Semilleros', data: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChartLineas.Select(x => x.Value))),
                    backgroundColor: 'rgba(46,134,193,.75)', borderRadius: 8 }]
            },
            options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true } } }
        });
    </script>
}